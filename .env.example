# LightRoast Deliver — environment.
# Copy to .env and fill in real values before running.

# Admin credentials (the single superuser).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT signing secret for the admin session cookie.
# MUST be at least 32 characters — the app refuses to start otherwise.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=generate-a-secure-random-string-here-min-32-chars

# Mark session cookies as Secure (HTTPS-only). Set true behind the Cloudflare
# tunnel (HTTPS); false only for plain-HTTP LAN access (e.g. http://nas-ip:3000).
COOKIE_SECURE=true

# Cloudflare Tunnel token (Zero Trust dashboard → Tunnels → your tunnel).
# Required only when running the `cloudflared` service in docker-compose.yml.
TUNNEL_TOKEN=

# Where the NAS media is mounted inside the container (see docker-compose.yml).
NAS_MOUNT_PATH=/mnt/nas

# SQLite database file (lives on the ./data Docker volume).
DATABASE_URL=file:/data/db.sqlite
