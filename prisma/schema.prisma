// LightRoast Deliver — data layer.
// SQLite, file-based, persisted on the ./data Docker volume.

generator client {
  provider      = "prisma-client-js"
  // native = local dev; linux-musl-openssl-3.0.x = Alpine container runtime.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  // bcrypt hash, optional — a portal can be open or password-protected.
  password  String?
  // When false, the portal is fully unavailable: no viewing, unlocking, or
  // downloading, regardless of password state.
  accessEnabled Boolean @default(true)
  createdAt DateTime @default(now())

  projects Project[]

  @@index([createdAt])
}

model Project {
  id        String   @id @default(cuid())
  name      String
  clientId  String
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  files  File[]

  @@index([clientId])
}

model File {
  id        String   @id @default(cuid())
  name      String // display name
  path      String // absolute path on the mounted filesystem
  size      BigInt // bytes
  mimeType  String
  projectId String
  createdAt DateTime @default(now())

  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  downloads DownloadEvent[]

  @@index([projectId])
}

model PageView {
  id         String   @id @default(cuid())
  clientSlug String // which portal was viewed
  // Daily-rotating hash of ip+ua — counts unique visitors without storing a
  // cross-day identifier.
  visitorId  String
  ip         String
  country    String? // from cf-ipcountry when behind Cloudflare
  referrer   String?
  device     String // desktop | mobile | tablet
  browser    String?
  os         String?
  userAgent  String
  // Link-preview crawlers (WhatsApp, Instagram…) and bots: logged but
  // excluded from analytics.
  isBot      Boolean  @default(false)
  viewedAt   DateTime @default(now())

  @@index([clientSlug])
  @@index([viewedAt])
}

model DownloadEvent {
  id           String   @id @default(cuid())
  fileId       String
  clientSlug   String // which portal triggered the download
  // "download" or "preview" — previews are in-browser views, not saves.
  kind         String   @default("download")
  ip           String
  userAgent    String
  downloadedAt DateTime @default(now())

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([clientSlug])
  @@index([downloadedAt])
}
